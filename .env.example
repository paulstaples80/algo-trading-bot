# ── TradingView (for MCP server) ──────────────────────────────────────────────
TV_USERNAME=your_tradingview_username
TV_PASSWORD=your_tradingview_password

# ── Alpha Vantage ─────────────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your_key_here
AV_PREMIUM=0          # set to 1 if on a paid plan (disables 12s sleep between requests)

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_CHANNEL=#trading-bias

# ── Email (optional — Gmail example) ─────────────────────────────────────────
EMAIL_SENDER=you@gmail.com
EMAIL_PASSWORD=your-app-password          # Gmail: use an App Password, not your account password
EMAIL_RECIPIENT=you@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
